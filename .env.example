# Application
APP_NAME=Enterprise AI Operations Platform
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# PostgreSQL
POSTGRES_USER=aios_user
POSTGRES_PASSWORD=replace-with-a-secure-password
POSTGRES_DB=aios

DATABASE_URL=postgresql+psycopg2://aios_user:replace-with-a-secure-password@postgres:5432/aios

# Authentication
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI
OPENAI_API_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
